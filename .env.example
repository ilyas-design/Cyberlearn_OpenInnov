# Firebase Web App (required) — Spark (free) plan is enough; no paid API keys needed.
# Firebase Console → Project settings → Your apps → SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Seed script — pick ONE option below

# Option A (recommended): path to service account JSON
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Option B: inline service account credentials
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Option C: existing admin user
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=

# Teacher registration — server-only secret code for professor sign-up
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
TEACHER_ACCESS_CODE=

# Server-only — required for /api/auth/* routes (2FA verification)
# Use the same path as the seed script (Option A above)
# FIREBASE_SERVICE_ACCOUNT_PATH is already set above

# Docker / Chatbot
# Local dev (npm run dev): use localhost
# Docker (./run.sh): overridden automatically to http://chatbot-api:8080
CHATBOT_API_URL=http://localhost:8080
# Shared secret between Next.js and the Flask chatbot API (generate a random value)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CHATBOT_INTERNAL_API_KEY=
WEB_PORT=3000
CHATBOT_PORT=8080
MODEL_PORT=8000

# Chatbot model (optional — requires NVIDIA GPU)
# Leave empty to run without local vLLM (chatbot falls back to FAQ answers)
# COMPOSE_PROFILES=local_model
MODEL_NAME=HuggingFaceTB/SmolLM2-135M-Instruct
MODEL_URL=http://model:8000/v1
# Generate with: node -e "console.log('sk-cyberlearn-' + require('crypto').randomBytes(32).toString('hex'))"
API_KEY=
